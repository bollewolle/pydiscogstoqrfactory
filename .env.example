# Python path (src layout)
PYTHONPATH=src

# Flask configuration
FLASK_APP=pydiscogsqrcodegenerator
FLASK_DEBUG=1
FLASK_RUN_PORT=5001

# Discogs API credentials (for initial authentication)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# Discogs API OAuth credentials
DISCOGS_OAUTH_TOKEN=
DISCOGS_OAUTH_TOKEN_SECRET=

# Frontend URL (must match where the app is running)
FRONTEND_URL=http://localhost:5001

# User agent for Discogs API
USERAGENT=pydiscogsqrcodegenerator/1.0
